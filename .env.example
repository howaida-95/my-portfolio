# Contact form (Nodemailer + SMTP)
# Copy to .env.local and fill in values. Never commit .env.local.
#
# Gmail example (use an App Password, not your normal password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=xxxx xxxx xxxx xxxx
#   MAIL_TO=you@gmail.com
#   MAIL_FROM=you@gmail.com
#
# Port 465 often needs SMTP_SECURE=true (implicit TLS).

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Inbox that receives contact form submissions
MAIL_TO=
# Optional; defaults to SMTP_USER (must be allowed by your provider)
MAIL_FROM=
